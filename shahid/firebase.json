{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],

    "headers": [
      {
        "source": "/sitemap.xml",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/xml"
          }
        ]
      }
    ],

    "rewrites": [
      {
        "source": "!/sitemap.xml",
        "destination": "/index.html"
      }
    ]
  }
}
